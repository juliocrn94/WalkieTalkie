# ─── Twilio ───────────────────────────────────────────────────────────────────
# Found in: https://console.twilio.com → Account Info
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# The public URL this server is reachable at (no trailing slash).
# Local dev: use your ngrok HTTPS URL (e.g. https://abc123.ngrok.io)
# Production: your deployed domain (e.g. https://sms.yourcompany.com)
WEBHOOK_BASE_URL=https://your-ngrok-or-domain-here.com

# ─── Slack ────────────────────────────────────────────────────────────────────
# Bot token from your Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Default channel to post in when a number has no channel override.
# Use the channel ID (e.g. C0123456789) — more reliable than names.
SLACK_DEFAULT_CHANNEL=C0123456789

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
